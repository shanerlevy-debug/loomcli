# Powerloom reconciler daemon — environment template.
#
# Copy to .env in the same directory before `docker compose up`:
#   cp .env.example .env
# Edit values, then:
#   docker compose up -d
#
# DO NOT commit a populated .env to git. The repo's .gitignore covers
# *.env at the root; this directory inherits.

# ----------------------------------------------------------------------
# Required: operator's PAT, minted via the UI at /settings/access-tokens.
# ----------------------------------------------------------------------
# Mint flow:
#   1. Sign into https://app.powerloom.org as an operator with
#      `agent:read` on the reconciler agent's OU.
#   2. /settings/access-tokens -> "New token" -> name + expiry -> mint.
#   3. Copy the `pat_...` value (shown once, once-only — store it here
#      or paste into your secrets manager and reference from there).
POWERLOOM_ACCESS_TOKEN=pat_REPLACE_ME

# ----------------------------------------------------------------------
# Optional: control-plane URL.
# ----------------------------------------------------------------------
# Defaults to api.powerloom.org. Override only for self-hosted control
# planes or for pointing at a staging cluster.
# POWERLOOM_API_BASE_URL=https://api.powerloom.org

# ----------------------------------------------------------------------
# Optional: which agent the daemon runs.
# ----------------------------------------------------------------------
# Default 'reconciler' resolves the bare-name agent in the operator's
# org. Use a UUID or /ou/path/agent-name for ambiguous cases.
# POWERLOOM_AGENT=reconciler

# ----------------------------------------------------------------------
# Optional: daemon flags.
# ----------------------------------------------------------------------
# Tick cadence in seconds. 10 is the default; bump to 30+ for low-volume
# orgs. Anything below 5 is wasteful (work-queue cooldown is 5 min).
# RECONCILER_INTERVAL=10

# Action confidence threshold. Decisions below this are log-only; at or
# above this, /reconciler/{rebase,merge} fire. Default 0.8.
# RECONCILER_CONFIDENCE=0.8

# Dry-run mode — daemon decides but doesn't take destructive actions.
# Set to "true" (or any non-empty value) to enable. Useful for the first
# 24-48 hours of dogfood while you watch decisions land before letting
# the daemon act.
# RECONCILER_DRY_RUN=true
