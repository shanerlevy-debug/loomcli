{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schema.powerloom.app/v2/stdlib/mcp-deployment.schema.json",
  "title": "MCPDeployment (v2 stdlib derivation)",
  "description": "A Powerloom-managed MCP server deployment from a template. Derivation: compose(Process[mcp_runtime], Policy[isolation_mode, config, policy], Scope[owner]). Shape parity with v1.2.0.",
  "type": "object",
  "x-powerloom-derivation": {
    "of": ["Process", "Policy", "Scope"],
    "roles": {
      "Process": "mcp_runtime",
      "Policy": "deployment_policy",
      "Scope": "ownership"
    }
  },
  "x-powerloom-apply-order": 70,
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": { "$ref": "../common.schema.json#/$defs/api_version" },
    "kind": { "const": "MCPDeployment" },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "ou_path"],
      "properties": {
        "name": {
          "$ref": "../common.schema.json#/$defs/resource_name",
          "x-powerloom-immutable": true
        },
        "ou_path": {
          "$ref": "../common.schema.json#/$defs/ou_path",
          "x-powerloom-ref": { "kind": "OU", "resolve_by": "path" },
          "x-powerloom-immutable": true
        }
      }
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["display_name", "template_kind"],
      "properties": {
        "display_name": { "$ref": "../common.schema.json#/$defs/display_name" },
        "template_kind": {
          "type": "string",
          "enum": [
            "files", "postgres", "slack", "echo", "powerloom_meta",
            "github", "google_drive", "notion", "jira", "confluence",
            "microsoft365", "salesforce", "zendesk", "hubspot", "linear"
          ],
          "x-powerloom-immutable": true,
          "x-powerloom-reconciler-hint": {
            "reconcilers": ["mcp"],
            "on_change": "full-reconcile",
            "cost": "expensive"
          }
        },
        "isolation_mode": {
          "type": "string",
          "enum": ["shared", "dedicated"],
          "default": "shared",
          "x-powerloom-immutable": true
        },
        "config": {
          "type": "object",
          "default": {},
          "x-powerloom-reconciler-hint": {
            "reconcilers": ["mcp"],
            "on_change": "full-reconcile",
            "cost": "expensive"
          }
        },
        "policy": {
          "type": "object",
          "default": {}
        }
      }
    }
  }
}
