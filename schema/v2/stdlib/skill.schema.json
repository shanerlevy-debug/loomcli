{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schema.powerloom.app/v2/stdlib/skill.schema.json",
  "title": "Skill (v2 stdlib derivation)",
  "description": "An Anthropic Claude Skill package uploaded to Powerloom. Derivation: compose(Process[skill_runtime], Policy[auto_attach_to, system]). Shape parity with v1.2.0.",
  "type": "object",
  "x-powerloom-derivation": {
    "of": ["Process", "Policy"],
    "roles": {
      "Process": "skill_runtime",
      "Policy": "auto_attach"
    }
  },
  "x-powerloom-apply-order": 50,
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": { "$ref": "../common.schema.json#/$defs/api_version" },
    "kind": { "const": "Skill" },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "ou_path"],
      "properties": {
        "name": {
          "$ref": "../common.schema.json#/$defs/resource_name",
          "x-powerloom-immutable": true
        },
        "ou_path": {
          "$ref": "../common.schema.json#/$defs/ou_path",
          "x-powerloom-ref": { "kind": "OU", "resolve_by": "path" },
          "x-powerloom-immutable": true
        }
      }
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["display_name"],
      "properties": {
        "display_name": { "$ref": "../common.schema.json#/$defs/display_name" },
        "description": {
          "type": ["string", "null"],
          "maxLength": 2048
        },
        "skill_type": {
          "type": "string",
          "enum": ["archive", "tool_definition"],
          "default": "archive",
          "x-powerloom-immutable": true
        },
        "tool_schema": {
          "type": ["object", "null"],
          "default": null,
          "x-powerloom-reconciler-hint": {
            "reconcilers": ["skill"],
            "on_change": "full-reconcile",
            "cost": "expensive"
          }
        },
        "current_version_id": {
          "oneOf": [
            { "$ref": "../common.schema.json#/$defs/uuid" },
            { "type": "null" }
          ],
          "x-powerloom-reconciler-hint": {
            "reconcilers": ["skill"],
            "on_change": "full-reconcile",
            "cost": "expensive"
          }
        },
        "system": {
          "type": "boolean",
          "default": false,
          "description": "Marks skill as system-authored; auto-attached per auto_attach_to selector."
        },
        "auto_attach_to": {
          "oneOf": [
            {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "agent_kinds": {
                  "type": "array",
                  "items": { "type": "string", "enum": ["user", "service"] },
                  "uniqueItems": true
                },
                "task_kinds": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "enum": ["routing", "qa", "analogy", "execution", "coordination"]
                  },
                  "uniqueItems": true
                },
                "runtime_types": {
                  "type": "array",
                  "items": { "type": "string" },
                  "uniqueItems": true
                },
                "coordinator_role_required": {
                  "type": "boolean",
                  "default": false
                }
              }
            },
            { "type": "null" }
          ],
          "default": null
        }
      }
    }
  }
}
