{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schema.powerloom.app/v1/kinds/workflow-type.schema.json",
  "title": "WorkflowType",
  "description": "Declarative workflow-type manifest. Creates or updates a workflow_type row that subsequent Workflow + Agent manifests reference. Added in schema 1.2.0.",
  "type": "object",
  "required": [
    "apiVersion",
    "kind",
    "metadata",
    "spec"
  ],
  "properties": {
    "apiVersion": {
      "const": "powerloom.app/v1"
    },
    "kind": {
      "const": "WorkflowType"
    },
    "metadata": {
      "type": "object",
      "required": [
        "name",
        "ou_id"
      ],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$",
          "minLength": 2,
          "maxLength": 64,
          "description": "Stable identifier within the OU. Lowercase alphanumeric + hyphens."
        },
        "display_name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "description": {
          "type": "string",
          "maxLength": 2048
        },
        "ou_id": {
          "type": "string",
          "format": "uuid"
        },
        "labels": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    "spec": {
      "type": "object",
      "properties": {
        "coordinator_agent_id": {
          "type": "string",
          "format": "uuid",
          "description": "Optional reference to the Agent that coordinates runs of this workflow type (for LLM-coordinator dispatch)."
        },
        "default_timeout_seconds": {
          "type": "integer",
          "minimum": 1,
          "maximum": 86400,
          "default": 3600
        },
        "memory_policy_id": {
          "type": "string",
          "format": "uuid",
          "description": "Optional reference to a MemoryPolicy governing memory accumulation / review for runs of this workflow."
        },
        "task_kinds": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "routing",
              "qa",
              "analogy",
              "execution",
              "coordination"
            ]
          },
          "uniqueItems": true,
          "description": "Which task kinds workflows of this type handle. Drives context-assembler representation selection for participating agents."
        },
        "runtime_targets": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "cma",
              "openai",
              "anthropic_messages",
              "ollama",
              "bedrock",
              "vertex",
              "azure_openai",
              "mistral",
              "cohere",
              "langchain",
              "crewai",
              "autogen"
            ]
          },
          "uniqueItems": true,
          "description": "Optional allowlist of runtime_types workflows of this type can dispatch to. Empty = any."
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
