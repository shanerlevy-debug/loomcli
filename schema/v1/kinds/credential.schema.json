{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schema.powerloom.app/v1/kinds/credential.schema.json",
  "title": "Credential",
  "description": "A bearer credential minted for an agent to authenticate against a specific MCP server registration. Spec is empty — the bearer is server-issued and stored in the CredentialStore; manifests never contain secret values.",
  "type": "object",
  "x-powerloom-apply-order": 40,
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "metadata"],
  "properties": {
    "apiVersion": { "$ref": "../common.schema.json#/$defs/api_version" },
    "kind": { "const": "Credential" },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["agent_path", "mcp_registration_path"],
      "properties": {
        "agent_path": {
          "$ref": "../common.schema.json#/$defs/agent_path",
          "x-powerloom-ref": { "kind": "Agent", "resolve_by": "path" },
          "x-powerloom-immutable": true
        },
        "mcp_registration_path": {
          "$ref": "../common.schema.json#/$defs/mcp_registration_path",
          "x-powerloom-ref": { "kind": "MCPServerRegistration", "resolve_by": "path" },
          "x-powerloom-immutable": true
        }
      }
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "description": "No spec. The bearer is minted server-side; the credential is immutable; rotate by deleting + recreating."
    }
  }
}
